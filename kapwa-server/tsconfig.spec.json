{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "types": ["jest", "node"],
    "esModuleInterop": true
  },
  "include": ["src/**/*.spec.ts"],
  "exclude": ["node_modules", "dist"]
}
